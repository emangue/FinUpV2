# =============================================================================
# .env.prod.example — Template de variáveis de produção FinUp
# =============================================================================
#
# INSTRUÇÕES:
#   1. Copie: cp .env.prod.example .env.prod
#   2. Preencha TODOS os valores marcados com CHANGE_ME
#   3. NUNCA commite .env.prod no git (já está no .gitignore)
#   4. No servidor: chmod 600 .env.prod
#
# Gerar secrets seguros:
#   JWT_SECRET_KEY    : python3 -c "import secrets; print(secrets.token_hex(32))"
#   POSTGRES_PASSWORD : openssl rand -base64 32 | tr -d '=+/'
#   REDIS_PASSWORD    : openssl rand -base64 24 | tr -d '=+/'
# =============================================================================

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=finup_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
POSTGRES_DB=finup_db

# ─── Backend ──────────────────────────────────────────────────────────────────
# 'postgres' = nome do serviço Docker (não localhost)
DATABASE_URL=postgresql://finup_user:CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS@postgres:5432/finup_db
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32

# CORS: domínios permitidos (sem espaços, separados por vírgula)
BACKEND_CORS_ORIGINS=https://meufinup.com.br,https://admin.meufinup.com.br

DEBUG=false
DOCS_ENABLED=false
ENVIRONMENT=production

# ─── Frontend (baked no build — deve ser URL pública) ──────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://meufinup.com.br

# ─── CI/CD — GitHub Container Registry ────────────────────────────────────────
# Preenchido automaticamente pelo GitHub Actions durante o deploy.
# Preencha GHCR_OWNER manualmente na configuração inicial.
GHCR_OWNER=emangue

# Imagens (atualizadas automaticamente pelo GitHub Actions)
GHCR_IMAGE_BACKEND=ghcr.io/emangue/finup-backend:latest
GHCR_IMAGE_FRONTEND=ghcr.io/emangue/finup-frontend:latest
GHCR_IMAGE_ADMIN=ghcr.io/emangue/finup-admin:latest

# Tag da imagem em produção (SHA do commit — atualizado pelo Actions)
IMAGE_TAG=latest

# Token de leitura do GHCR (GitHub PAT com escopo read:packages)
# Criar em: GitHub → Settings → Developer settings → Personal access tokens
GHCR_TOKEN=CHANGE_ME_GITHUB_PAT_WITH_READ_PACKAGES
